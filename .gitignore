# Local editor / IDE state
.vscode/
.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# tweakcc working-directory artifacts we deliberately do NOT mirror
native-binary.backup
native-claudejs-orig.js
native-claudejs-patched.js
systemPromptAppliedHashes.json
systemPromptOriginalHashes.json
cli.js.backup
config.json
prompt-data-cache/
system-prompts/*.diff.html

# Claude Code / Serena / other tool state
# Everything under .claude/ is local state EXCEPT the `skills/` subdir,
# which holds project-scoped skill definitions that belong in git.
.claude/*
!.claude/skills/
.serena/

# Node deps for scripts/ (gray-matter is pinned in scripts/package.json;
# the lockfile is checked in for reproducibility).
scripts/node_modules/

# lib/ deps: package.json + our .mjs are committed, but node_modules is NOT —
# node-lief is a platform-specific native addon that upgrade.sh / install.sh
# `npm install` locally on first run.
lib/node_modules/

# Python bytecode cache from apply-unnerfs.py
scripts/__pycache__/
__pycache__/
*.pyc
